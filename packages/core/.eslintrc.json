{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended"],
  "env": {
    "browser": true,
    "node": true,
    "es2022": true,
    "worker": true
  },
  "globals": {
    "ReadableStream": "readonly",
    "performance": "readonly",
    "requestAnimationFrame": "readonly"
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "@typescript-eslint/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "args": "none"
      }
    ],
    "@typescript-eslint/no-explicit-any": "warn",
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": [
              "@voai/admin*",
              "@voai/pro*",
              "**/admin-web/**",
              "**/voai-pro/**"
            ],
            "message": "Open-Core Boundary: @craft-codex/core must KEINE proprietary/Admin Imports haben."
          },
          {
            "group": ["@supabase/*", "**/supabase/**"],
            "message": "Open-Core Boundary: Supabase ist proprietary-only. Open-Core nutzt better-sqlite3."
          },
          {
            "group": ["livekit-*", "@livekit/*"],
            "message": "Open-Core Boundary: LiveKit (Live-Call) ist proprietary-only und Phase B."
          },
          {
            "group": ["next", "next/*"],
            "message": "Open-Core Boundary: @craft-codex/core is framework-agnostisch."
          }
        ]
      }
    ]
  },
  "ignorePatterns": ["dist", "node_modules", "tests"]
}
