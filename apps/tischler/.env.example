# Craft Codex / Tischler — Beispiel-Env (lokal als .env.local kopieren).
# Alle Keys werden NUR serverseitig (app/api/voice/*) genutzt — niemals
# NEXT_PUBLIC_* setzen, sonst landet der Key im Browser-Bundle (CI bricht ab).
# Ohne Keys läuft die Demo offline im Mock/Template-Modus (kein Crash).

# ── Stimme: Antwort (RAG-geerdet) + TTS ─────────────────────────────────
# Default-Provider ist Google Gemini (ein Key für Answer UND TTS).
GEMINI_API_KEY=

# Optional: Gemini-Feintuning
# GEMINI_TTS_VOICE=Kore                     # Prebuilt-Stimme (klar, dt.)
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# GEMINI_ANSWER_MODEL=

# ── Provider-Auswahl (optional, sonst Auto: gemini wenn GEMINI_API_KEY) ──
# TTS_PROVIDER=gemini        # gemini | elevenlabs
# ANSWER_PROVIDER=gemini     # gemini | claude

# ── Alternative Provider (optional, NICHT für den Prototyp nötig) ───────
# ANTHROPIC_API_KEY=         # Answer via Claude statt Gemini
# OPENAI_API_KEY=            # STT via Whisper (Mikrofon-Diktat)
# ELEVENLABS_API_KEY=        # TTS via ElevenLabs statt Gemini
# ELEVENLABS_VOICE_ID=
